# This .env file is here just to document that all of these variables
# are needed to run the tests. Their values are not provided here
# because we don't want to commit secrets to the git repository.
#
# Make sure you provide the actual values when you run the
# `start-dev.sh` script (e.g., by doing something like
#
#   env COGNITO_TESTS_AUDIENCE='actual-value' ....  start-dev.sh
#
COGNITO_TESTS_AUDIENCE=do-not-put-the-real-value-here!
COGNITO_TESTS_ISSUER_URL=do-not-put-the-real-value-here!
COGNITO_TESTS_JWKS_URI=do-not-put-the-real-value-here!
COGNITO_TESTS_PASSWORD=do-not-put-the-real-value-here!
COGNITO_TESTS_SUB=do-not-put-the-real-value-here!
COGNITO_TESTS_USERNAME=do-not-put-the-real-value-here!
COGNITO_TESTS_USER_POOL_CLIENT_ID=do-not-put-the-real-value-here!
